{
  "name": "crypto-arbitrage-scanner",
  "version": "1.0.0",
  "description": "Cross-Exchange Crypto Arbitrage Scanner",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win",
    "pack": "electron-builder --dir",
    "publish": "electron-builder --win -p always"
  },
  "author": "Твоє Ім'я",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "https://github.com/ТВІЙ_ГІТХАБ_ЛОГІН/ТВІЙ_РЕПОЗИТОРІЙ.git"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "electron-updater": "^6.1.8",
    "node-telegram-bot-api": "^0.65.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.cryptoarb.app",
    "productName": "Crypto Arb Pro",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": ["nsis"]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": [
      {
        "provider": "github",
        "owner": "ТВІЙ_ГІТХАБ_ЛОГІН",
        "repo": "ТВІЙ_РЕПОЗИТОРІЙ"
      }
    ]
  }
}
